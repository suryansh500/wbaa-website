<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>

<%- include('partials/navbar') %>

<section class="training-page py-5">
  <div class="container">

    <h2 class="section-title mb-5">
      Training Centres
    </h2>

    <% if (!grouped || Object.keys(grouped).length === 0) { %>
      <p class="text-center text-muted">No training centres added yet.</p>
    <% } %>

    <% for (let district in grouped) { %>

      <div class="district-block mb-5">
        <h4 class="district-title mb-4"><%= district %></h4>

        <div class="row g-4">

          <% grouped[district].forEach(c => { %>

            <div class="col-md-6">
              <div class="centre-card h-100">

                <h6 class="fw-bold mb-1">
                  <%= c.centreName || 'Training Centre' %>
                </h6>

                <p class="mb-1">
                  <strong>Head:</strong> <%= c.headName %>
                </p>

                <p class="mb-1">
                  <strong>Phone:</strong> <%= c.phone || '-' %>
                </p>

                <p class="text-muted small mb-0">
                  <%= c.address || '-' %>
                </p>

              </div>
            </div>

          <% }) %>

        </div>
      </div>

    <% } %>

  </div>
</section>

<%- include('partials/footer') %>

</body>
</html>