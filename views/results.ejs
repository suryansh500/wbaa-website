<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/navbar') %>
    <!-- RESULTS PAGE -->
  <section class="results-page py-5">
    <div class="container">

      <h2 class="section-title mb-5">
        Tournament Results
      </h2>

<% if (!groupedResults || Object.keys(groupedResults).length === 0) { %>
  <p class="text-center text-muted">No tournaments added yet.</p>
<% } else { %>

  <% groupedResults.forEach(group => { %>
  <div class="results-year mb-5">
    <h4 class="year-title mb-4"><%= group.year %></h4>

    <div class="row g-4">
      <% group.tournaments.forEach(tournament => { %>
        <div class="col-6 col-md-4 col-lg-3">
          <a href="/results/<%= tournament._id %>" class="tournament-card">
            <img src="<%= tournament.poster?.url || '/images/default.jpg' %>" alt="Poster">
            <div class="tournament-info">
              <h6><%= tournament.name %></h6>
              <p><%= tournament.date.toDateString() %></p>
            </div>
          </a>
        </div>
      <% }) %>
    </div>
  </div>
<% }) %>
<% } %>

    </div>
  </section>
    <%- include('partials/footer') %>
</body>
</html>