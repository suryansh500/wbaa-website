<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body>

<%- include('../partials/navbar') %>

<section class="results-page py-5">
  <div class="container">

    <h2 class="section-title mb-5">Manage Results</h2>

    <% if (!tournaments || tournaments.length === 0) { %>
      <p class="text-center text-muted">No tournaments found.</p>
    <% } %>

    <div class="row g-4">
      <% tournaments.forEach(tournament => { %>
        <div class="col-6 col-md-4 col-lg-3">

          <div class="tournament-card">

            <!-- poster -->
            <img
              src="<%= tournament.poster?.url || '/images/default.jpg' %>"
              alt="Poster"
            >

            <div class="tournament-info">
              <h6><%= tournament.name %></h6>
              <p><%= tournament.date.toDateString() %></p>

              <!-- buttons -->
              <div class="d-flex gap-2 justify-content-center mt-2">

                <a href="/admin/tournaments/<%= tournament._id %>/edit"
                   class="btn btn-sm btn-primary">
                  Edit
                </a>

                <form action="/admin/tournaments/<%= tournament._id %>/delete"
                      method="POST"
                      onsubmit="return confirm('Delete this tournament?')">
                  <button class="btn btn-sm btn-danger">
                    Delete
                  </button>
                </form>

              </div>
            </div>

          </div>

        </div>
      <% }) %>
    </div>

  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
