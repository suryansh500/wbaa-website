<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body>

<%- include('../partials/navbar') %>

<div class="container py-4">
  <h3 class="mb-4">
  <%= isEdit ? 'Edit Tournament' : 'Add Tournament' %>
</h3>

  <form action="<%= isEdit ? '/admin/tournaments/' + tournament._id + '/update' : '/admin/tournaments' %>"
      method="POST"
      enctype="multipart/form-data">

    <!-- SECTION 1: TOURNAMENT DETAILS -->
    <h5>1. Tournament Details</h5>

    <div class="mb-2">
      <label class="form-label">Tournament Name</label>
      <input type="text" class="form-control" name="name" value="<%= tournament?.name || '' %>" required>
    </div>

    <div class="mb-2">
      <label class="form-label">Location</label>
      <input type="text" class="form-control" name="location" value="<%= tournament?.location || '' %>">
    </div>

    <div class="mb-2">
      <label class="form-label">Date</label>
      <input type="date" class="form-control" name="date"  value="<%= tournament?.date ? tournament.date.toISOString().split('T')[0] : '' %>" required>
    </div>
  <div class="mb-3">
  <label class="form-label">Poster Image</label>

  <% if (isEdit && tournament?.poster?.url) { %>
    <div class="mb-2">
      <img src="<%= tournament.poster.url %>" style="height:120px;border-radius:8px;">
      <div>
        <label class="text-danger">
        <input type="checkbox" name="removePoster" value="1">
        Remove poster
      </label>
      </div>
    </div>
  <% } %>

  <input type="file" class="form-control" name="poster" accept="image/*">
</div>

    <hr>

    <!-- SECTION 2: CATEGORIES & RESULTS -->
    <h5>2. Categories & Results</h5>

<div id="categories"></div>

<% if (isEdit && tournament?.categories?.length) { %>
<script>
  const existingCategories = JSON.parse('<%- JSON.stringify(tournament.categories) %>');

  window.addEventListener('DOMContentLoaded', () => {
    existingCategories.forEach(cat => addCategory(cat));
  });
</script>
<% } %>

    <button type="button" class="btn btn-outline-primary btn-sm mb-3" onclick="addCategory()">
      ➕ Add Category
    </button>

    <hr>

    <!-- SECTION 3: MEDIA -->
    <h5>3. Media</h5>
    <% if (isEdit && tournament) { %>

<!-- EXISTING IMAGES -->
<% if (tournament.gallery?.images?.length) { %>
<div class="existing-media mb-3">
  <label class="form-label">Current Images</label>

  <div class="d-flex flex-wrap gap-2">
    <% tournament.gallery.images.forEach(img => { %>
      <div class="media-thumb">
        <img src="<%= img.url %>">
        <button type="button"
                class="media-remove"
                onclick="markMediaDelete('images','<%= img.public_id %>', this)">
          ✕
        </button>
      </div>
    <% }) %>
  </div>
</div>
<% } %>

<!-- EXISTING VIDEOS -->
<% if (tournament.gallery?.videos?.length) { %>
<div class="existing-media mb-3">
  <label class="form-label">Current Videos</label>

  <div class="d-flex flex-wrap gap-2">
    <% tournament.gallery.videos.forEach(v => { %>
      <div class="media-thumb">
        <video src="<%= v.url %>" muted></video>
        <button type="button"
                class="media-remove"
                onclick="markMediaDelete('videos','<%= v.public_id %>', this)">
          ✕
        </button>
      </div>
    <% }) %>
  </div>
</div>
<% } %>

<% } %>
    <div class="mb-2">
      <label class="form-label">Gallery Images</label>
      <input type="file" class="form-control" name="images" accept="image/*" multiple>
    </div>

    <div class="mb-3">
      <label class="form-label">Videos</label>
      <input type="file" class="form-control" name="videos" accept="video/*" multiple>
    </div>
    <input type="hidden" name="removeImages" id="removeImages">
    <input type="hidden" name="removeVideos" id="removeVideos">
    <button class="btn btn-success">Save Tournament</button>

  </form>
</div>

<script>
let categoryCount = 0;

function addCategory(data = {}) {
  categoryCount++;

  const div = document.createElement('div');
  div.className = 'border rounded p-3 mb-3';

  div.innerHTML = `
    <h6>Category ${categoryCount}</h6>

    <div class="row mb-2">
      <div class="col">
        <label>Gender</label>
        <select class="form-control" name="gender[]">
          <option ${data.gender === 'Men' ? 'selected' : ''}>Men</option>
          <option ${data.gender === 'Women' ? 'selected' : ''}>Women</option>
        </select>
      </div>

      <div class="col">
        <label>Division</label>
        <select class="form-control" name="division[]">
          <option ${data.division === 'Senior' ? 'selected' : ''}>Senior</option>
          <option ${data.division === 'Junior' ? 'selected' : ''}>Junior</option>
          <option ${data.division === 'Open' ? 'selected' : ''}>Open</option>
        </select>
      </div>

      <div class="col">
        <label>Hand</label>
        <select class="form-control" name="hand[]">
          <option ${data.hand === 'Right' ? 'selected' : ''}>Right</option>
          <option ${data.hand === 'Left' ? 'selected' : ''}>Left</option>
        </select>
      </div>
    </div>

    <div class="mb-2">
      <label>Weight Category</label>
      <input class="form-control" name="weight[]" value="${data.weight || ''}">
    </div>

    <div class="row mb-2">
      <div class="col"><input class="form-control" name="first[]" value="${data.results?.first || ''}" placeholder="🥇 1st"></div>
      <div class="col"><input class="form-control" name="second[]" value="${data.results?.second || ''}" placeholder="🥈 2nd"></div>
      <div class="col"><input class="form-control" name="third[]" value="${data.results?.third || ''}" placeholder="🥉 3rd"></div>
    </div>

    <div class="row mb-2">
      <div class="col"><input class="form-control" name="fourth[]" value="${data.results?.fourth || ''}" placeholder="4th (optional)"></div>
      <div class="col"><input class="form-control" name="fifth[]" value="${data.results?.fifth || ''}" placeholder="5th (optional)"></div>
    </div>

    <button type="button" class="btn btn-sm btn-danger" onclick="this.parentElement.remove()">Remove</button>
  `;

  document.getElementById('categories').appendChild(div);
}
</script>
<script>
function markMediaDelete(type, publicId, btn) {
  // remove from UI instantly
  btn.parentElement.remove();

  // poster
  if (type === 'poster') {
    document.getElementById('removePoster').value = publicId;
  }

  // images
  if (type === 'images') {
    const input = document.getElementById('removeImages');
    const arr = input.value ? input.value.split(',') : [];
    arr.push(publicId);
    input.value = arr.join(',');
  }

  // videos
  if (type === 'videos') {
    const input = document.getElementById('removeVideos');
    const arr = input.value ? input.value.split(',') : [];
    arr.push(publicId);
    input.value = arr.join(',');
  }
}
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
