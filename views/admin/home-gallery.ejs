<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <h3 class="mb-4">Manage Home Gallery</h3>

  <!-- Upload form -->
  <form id="galleryForm"
      action="/admin/home-gallery/update"
      method="POST"
      enctype="multipart/form-data">

    <div class="mb-3">
        <input
            type="file"
            name="images"
            multiple
            class="form-control">
    </div>
    <div class="mt-4">
    <button type="submit" class="btn btn-success">
        ✔ Save Changes
    </button>
</div>

</form>

  <!-- Existing images -->
  <div class="row g-3">
    <% images.forEach(img => { %>
      <div class="col-6 col-md-3">
        <div class="position-relative">
          <img src="<%= img.url %>" class="img-fluid rounded shadow-sm">

          <button
type="button"
class="btn btn-danger btn-sm position-absolute top-0 end-0"
onclick="markHomeDelete('<%= img.public_id %>', this)">
✕
</button>
        </div>
      </div>
    <% }) %>
  </div>
</div>
<script>

const form = document.getElementById("galleryForm");

function markHomeDelete(publicId, btn){

    const hidden=document.createElement("input");

    hidden.type="hidden";

    hidden.name="removeImages";

    hidden.value=publicId;

    form.appendChild(hidden);

    btn.closest(".col-6").style.display="none";

}

</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>